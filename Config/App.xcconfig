// Shared app configuration that is safe to commit.
// Personal signing details belong in Config/Local.xcconfig, which is gitignored.
#include "AppVersion.xcconfig"
#include? "Local.xcconfig"

APP_NAME = Climate Closet
APP_BUNDLE_ID_BASE = com.raelldottin.ClimateCloset

APP_DISPLAY_NAME = $(APP_NAME)
APP_DISPLAY_NAME[config=Debug] = $(APP_NAME) Debug

APP_BUNDLE_IDENTIFIER = $(APP_BUNDLE_ID_BASE)
APP_BUNDLE_IDENTIFIER[config=Debug] = $(APP_BUNDLE_ID_BASE).debug

INFOPLIST_KEY_CFBundleDisplayName = $(APP_DISPLAY_NAME)
INFOPLIST_KEY_CFBundleShortVersionString = $(MARKETING_VERSION)
INFOPLIST_KEY_CFBundleVersion = $(CURRENT_PROJECT_VERSION)
PRODUCT_BUNDLE_IDENTIFIER = $(APP_BUNDLE_IDENTIFIER)
